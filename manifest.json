{
  "manifest_version": 3,
  "name": "Incitertech Time Tracker",
  "version": "1.0",
  "permissions": [
    "storage",
    "idle",
    "tabs",
    "activeTab",
    "alarms",
    "notifications",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://identitytoolkit.googleapis.com/*",
    "https://securetoken.googleapis.com/*",
    "https://firestore.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Login"
  },

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "128": "icons/icon.png"
  }
}
